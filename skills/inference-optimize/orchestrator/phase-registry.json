{
  "schema_version": "1.0",
  "v2_monitor": false,
  "human_loop": false,
  "max_context_lines": 8000,
  "context_value_char_limit": 800,
  "context_keys_preview": 10,
  "context_items_preview": 5,
  "cursor_agent_doc_max_lines": 600,
  "dispatcher": {
    "outer_summary_template": "monitor/phase-{NN}-orchestration-summary.md",
    "outer_max_context_files": 3,
    "phase_orchestrator_doc": "orchestrator/PHASE-ORCHESTRATOR.md"
  },
  "phases": {
    "env": {
      "index": 0,
      "agent": "phase-00-env-setup.md",
      "deps": [],
      "critical": false,
      "required_context": ["CONFIG_KEY", "OUTPUT_DIR", "MODE", "REPO_DIR", "REPO_URL", "HF_CACHE", "SCRIPTS_DIR", "GEAK_DIR", "GEAK_OE_DIR", "ENV_INFO_FILE"],
      "sticky": ["gpu_arch", "gpu_count", "container_image"]
    },
    "config": {
      "index": 1,
      "agent": "phase-01-config-parse.md",
      "deps": ["env"],
      "critical": false,
      "required_context": ["CONFIG_KEY", "OUTPUT_DIR", "REPO_DIR", "SCRIPTS_DIR", "FILTER_EP", "FILTER_TP", "FILTER_CONC_START", "FILTER_CONC_END", "FILTER_SEQ"],
      "sticky": ["tp_size", "ep_size", "seq_lengths", "concurrency_levels"]
    },
    "benchmark": {
      "index": 2,
      "agent": "phase-02-benchmark.md",
      "deps": ["config"],
      "critical": true,
      "required_context": ["CONFIG_KEY", "OUTPUT_DIR", "SCRIPTS_DIR", "REPO_DIR", "HF_CACHE", "PROFILE_DIR", "GPUS", "DRY_RUN_NOTE"],
      "sticky": ["baseline_tpot", "baseline_throughput"],
      "monitor_context_fields": {
        "source_artifacts": [],
        "scalars": ["benchmark_result_status", "benchmarks_succeeded", "baseline_artifacts_ready"]
      },
      "quality": {
        "checks": [
          { "name": "results_exist", "type": "file_exists", "path": "results/" },
          { "name": "runs_completed", "type": "metric_threshold", "field": "benchmarks_succeeded", "min": 1 }
        ],
        "detection_rules": "Fail benchmark when any of: expected result JSONs are missing; benchmarks_succeeded < 1; throughput artifacts are present but invalid or clearly incomplete; the benchmark phase reports an environment or harness issue that makes downstream comparison unsafe.",
        "detection_rules_structured": [
          {"field": "benchmarks_succeeded", "op": "lt", "value": 1, "verdict": "FAIL"},
          {"field": "benchmark_result_status", "op": "eq", "value": "failed", "verdict": "FAIL"},
          {"field": "baseline_artifacts_ready", "op": "eq", "value": false, "verdict": "FAIL"}
        ]
      },
      "rca_artifact": {
        "output": "results/benchmark_rca.json",
        "analysis_context": [
          "agent-results/phase-02-result.md",
          "monitor/phase-02-review.md",
          "results/config_selection.json",
          "results/benchmark_summary.json"
        ]
      },
      "terminal_policy": "stop"
    },
    "benchmark-analyze": {
      "index": 3,
      "agent": "phase-03-benchmark-analyze.md",
      "deps": ["benchmark"],
      "critical": false,
      "required_context": ["OUTPUT_DIR", "SCRIPTS_DIR", "REPORT_DIR", "TEMPLATES_DIR"],
      "sticky": ["gap_analysis_summary", "best_concurrency"],
      "monitor_context_fields": {
        "source_artifacts": ["results/benchmark_summary.json"],
        "scalars": ["results_analyzed", "bottlenecks_found"]
      },
      "quality": {
        "checks": [
          { "name": "summary_exists", "type": "file_exists", "path": "results/benchmark_summary.json" },
          { "name": "results_analyzed", "type": "metric_threshold", "field": "results_analyzed", "min": 1 }
        ],
        "detection_rules": "Fail when benchmark_summary.json is missing or results_analyzed < 1.",
        "detection_rules_structured": [
          {"field": "results_analyzed", "op": "lt", "value": 1, "verdict": "FAIL"}
        ]
      }
    },
    "profile": {
      "index": 4,
      "agent": "phase-04-profile.md",
      "deps": ["config"],
      "critical": false,
      "required_context": ["CONFIG_KEY", "OUTPUT_DIR", "SCRIPTS_DIR", "REPO_DIR", "HF_CACHE", "PROFILE_DIR", "GPUS", "DRY_RUN_NOTE", "ENFORCE_EAGER_FLAG", "FILTER_EP", "FILTER_TP", "FILTER_CONC_START", "FILTER_CONC_END", "FILTER_SEQ"]
    },
    "profile-analyze": {
      "index": 5,
      "agent": "phase-05-profile-analyze.md",
      "deps": ["profile"],
      "critical": true,
      "required_context": ["OUTPUT_DIR", "GPU_ARCH", "SCRIPTS_DIR", "RESOURCES_DIR", "REPORT_DIR", "TEMPLATES_DIR", "PROFILE_DIR"],
      "sticky": ["top_kernels", "kernel_time_pct"],
      "monitor_context_fields": {
        "source_artifacts": ["results/trace_manifest.json"],
        "scalars": ["trace_integrity_status", "tracelens_status", "phase_split_status", "trace_count", "world_size", "phase_split_inputs_ready", "roofline_coverage_pct"]
      },
      "quality": {
        "checks": [
          { "name": "traces_valid", "type": "file_exists", "path": "profiles/" },
          { "name": "analysis_produced", "type": "file_exists", "path": "results/profile_analysis.json" },
          { "name": "trace_manifest_exists", "type": "file_exists", "path": "results/trace_manifest.json" }
        ],
        "detection_rules": "Fail profile analysis when any of: gzip decompression fails end-to-end; traceEvents are missing; trace files are trivially small or obviously incomplete; required primary trace or phase-split inputs are missing for optimize mode; TraceLens or phase-split roofline is required but not actually usable; roofline_coverage_pct < 50 (majority of top kernel time lacks roofline data, typically due to CUDA graph wrapping). Check trace_manifest.json for per-trace integrity status and phase_split_inputs_ready flag.",
        "detection_rules_structured": [
          {"field": "trace_integrity_status", "op": "eq", "value": "corrupt", "verdict": "FAIL"},
          {"field": "trace_integrity_status", "op": "eq", "value": "missing", "verdict": "FAIL"},
          {"field": "trace_count", "op": "lt", "value": 1, "verdict": "FAIL"},
          {"field": "phase_split_inputs_ready", "op": "eq", "value": false, "verdict": "FAIL"},
          {"field": "roofline_coverage_pct", "op": "lt", "value": 50, "verdict": "FAIL"}
        ]
      },
      "rca_artifact": {
        "output": "results/profile_rca.json",
        "analysis_context": [
          "agent-results/phase-05-result.md",
          "monitor/phase-05-review.md",
          "results/trace_manifest.json",
          "results/profile_analysis.json"
        ]
      },
      "fallback_target": "profile",
      "terminal_policy": "stop"
    },
    "problem-generate": {
      "index": 6,
      "agent": "phase-06-problem-generate.md",
      "deps": ["profile-analyze"],
      "requires_artifacts": [
        "results/gap_analysis/gap_analysis.json",
        "results/profile_analysis.json"
      ],
      "critical": true,
      "required_context": ["OUTPUT_DIR", "GPU_ARCH", "TOP_KERNELS", "SCRIPTS_DIR", "PROBLEMS_DIR", "OPTIMIZED_DIR", "RESOURCES_DIR", "RESULTS_DIR", "FRAMEWORK", "PRECISION", "OPTIMIZE_PRIORITY_THRESHOLD", "VLLM_VERSION", "KERNEL_SOURCE_MAP_PATH", "LIBRARY_PINS_PATH"],
      "sticky": ["optimization_targets", "forks_pinned"],
      "monitor_context_fields": {
        "source_artifacts": [
          "problems/optimization_manifest.json",
          "problems/redirect_plan.json",
          "problems/kernel_source_map_resolved.json",
          "forks/manifest.json",
          "results/baseline_dispatch_trace.json"
        ],
        "scalars": [
          "upstream_resolved_count",
          "unresolved_unknown_count",
          "unresolved_unknown_pct_of_top_time",
          "forks_pinned_count",
          "forks_required_count",
          "bucket_a_count",
          "bucket_b_count",
          "bucket_c_count",
          "bucket_b_user_proceed_count",
          "bucket_b_user_skip_count",
          "bucket_b_user_redirect_count",
          "dispatch_redirect_planned_count",
          "baseline_dispatch_trace_captured",
          "ck_branch_merged_status"
        ]
      },
      "quality": {
        "checks": [
          { "name": "manifest_exists", "type": "file_exists", "path": "problems/optimization_manifest.json" },
          { "name": "forks_manifest_exists", "type": "file_exists", "path": "forks/manifest.json" },
          { "name": "baseline_dispatch_trace_exists", "type": "file_exists", "path": "results/baseline_dispatch_trace.json" },
          { "name": "upstream_resolved", "type": "metric_threshold", "field": "upstream_resolved_count", "min": 1 }
        ],
        "detection_rules": "Fail when any of: optimization_manifest.json is missing; forks/manifest.json is missing; baseline_dispatch_trace.json is missing or empty; upstream_resolved_count < 1; unresolved_unknown_pct_of_top_time > 30 (the majority of top GPU time is unmapped); forks_pinned_count < forks_required_count (a required upstream library fork failed to clone or check out the pinned commit); a Bucket B kernel was passed through without a recorded user_decision (sum of bucket_b_user_*_count must equal bucket_b_count). Pass when at least one optimize=true entry exists with a resolved upstream source path. Bucket C / unresolved kernels must carry skip_reason populated.",
        "detection_rules_structured": [
          {"field": "upstream_resolved_count", "op": "lt", "value": 1, "verdict": "FAIL"},
          {"field": "baseline_dispatch_trace_captured", "op": "eq", "value": false, "verdict": "FAIL"},
          {"field": "unresolved_unknown_pct_of_top_time", "op": "gt", "value": 30.0, "verdict": "FAIL"}
        ]
      },
      "rca_artifact": {
        "output": "results/problem_gen_rca.json",
        "analysis_context": [
          "problems/optimization_manifest.json",
          "problems/redirect_plan.json",
          "problems/kernel_source_map_resolved.json",
          "problems/unresolved_kernels.json",
          "forks/manifest.json",
          "results/baseline_dispatch_trace.json",
          "results/profile_analysis.json",
          "agent-results/phase-06-result.md"
        ]
      },
      "terminal_policy": "stop"
    },
    "kernel-optimize": {
      "index": 7,
      "agent": "phase-07-kernel-optimize.md",
      "deps": ["problem-generate"],
      "requires_artifacts": [
        "problems/optimization_manifest.json",
        "forks/manifest.json"
      ],
      "critical": true,
      "required_context": ["OUTPUT_DIR", "GPU_ARCH", "SCRIPTS_DIR", "PROBLEMS_DIR", "RESULTS_DIR", "RESOURCES_DIR", "OPTIMIZED_DIR", "REPO_DIR", "HF_CACHE", "ENV_INFO_FILE", "OPTIMIZE_SCOPE", "GEAK_DIR", "GEAK_OE_DIR", "GPUS", "CONFIG_KEY", "KERNEL_SOURCE_MAP_PATH", "LIBRARY_PINS_PATH"],
      "monitor_context_fields": {
        "source_artifacts": [
          "problems/geak_results.json",
          "results/preflight_dispatch_trace.json",
          "results/profile_analysis.json"
        ],
        "scalars": [
          "library_tests_passed_count",
          "library_tests_failed_count",
          "allocator_test_pass",
          "dispatch_pre_flight_pass",
          "geak_speedup_lib_bench",
          "redirect_commits_applied_count",
          "in_place_winners_count",
          "redirect_winners_count",
          "no_harness_winners_count",
          "winners_total_count",
          "py_exports_shipped_count",
          "optimized_artifact_count",
          "optimized_dir_empty",
          "claimed_winner_artifacts_valid",
          "redirect_attempted",
          "redirect_count_observed",
          "redirect_count_expected",
          "redirect_count_ratio",
          "redirect_count_within_tolerance",
          "mini_ab_required",
          "mini_ab_harness_status",
          "unverified_per_kernel_count"
        ]
      },
      "quality": {
        "checks": [
          { "name": "geak_results_exists", "type": "file_exists", "path": "problems/geak_results.json" },
          { "name": "preflight_trace_exists", "type": "file_exists", "path": "results/preflight_dispatch_trace.json" },
          { "name": "winners_present", "type": "metric_threshold", "field": "winners_total_count", "min": 1 },
          { "name": "claimed_winner_artifacts_valid", "type": "metric_threshold", "field": "claimed_winner_artifacts_valid", "min": 1 }
        ],
        "detection_rules": "Fail kernel-optimize when any of: geak_results.json or preflight_dispatch_trace.json is missing; winners_total_count < 1 (the phase produced no usable patch shipped as a winner on any bucket — counting only shipped in_place + redirect + no_harness winners; redirect_commits_applied_count is audit-only and never counts as a winner); claimed_winner_artifacts_valid == false (the row claims a winner but its required integration artifact is missing or invalid); optimized_artifact_count == 0 while a winner is claimed (the optimized/ directory must contain integration-ready files when Phase 8 is expected to consume them); redirect_count_within_tolerance == false (a redirect was attempted but the observed dispatch count is outside the [0.5x, 1.5x] expected window — over- or under-routing); mini_ab_harness_status == 'unreliable_high_variance' when mini-A/B is required (per-bucket trim cannot run honestly); library_tests_failed_count > 0 (Bucket A library suite regressed against the patched fork); allocator_test_pass == false (Bucket A allocator-equivalent test diverged or HSA-faulted); dispatch_pre_flight_pass == false (rocprofv3 confirmed the patched symbol does not actually fire after rebuild). Bucket B winners are expected to carry optimization_unverified_per_kernel = true; do not fail the phase merely on unverified_per_kernel_count > 0.",
        "detection_rules_structured": [
          {"field": "dispatch_pre_flight_pass", "op": "eq", "value": false, "verdict": "FAIL"},
          {"field": "library_tests_failed_count", "op": "gt", "value": 0, "verdict": "FAIL"},
          {"field": "allocator_test_pass", "op": "eq", "value": false, "verdict": "FAIL"},
          {"field": "winners_total_count", "op": "lt", "value": 1, "verdict": "FAIL"},
          {"field": "claimed_winner_artifacts_valid", "op": "eq", "value": false, "verdict": "FAIL"},
          {"field": "optimized_artifact_count", "op": "lt", "value": 1, "verdict": "FAIL", "condition": "winners_total_count gt 0"},
          {"field": "redirect_count_within_tolerance", "op": "eq", "value": false, "verdict": "FAIL", "condition": "redirect_attempted == true"},
          {"field": "mini_ab_harness_status", "op": "eq", "value": "unreliable_high_variance", "verdict": "FAIL", "condition": "mini_ab_required == true"}
        ]
      },
      "rca_artifact": {
        "output": "results/kernel_opt_rca.json",
        "analysis_context": [
          "agent-results/phase-07-result.md",
          "monitor/phase-07-review.md",
          "problems/optimization_manifest.json",
          "problems/redirect_plan.json",
          "problems/geak_results.json",
          "results/preflight_dispatch_trace.json",
          "forks/manifest.json"
        ]
      },
      "fallback_target": "problem-generate",
      "terminal_policy": "stop"
    },
    "integration": {
      "index": 8,
      "agent": "phase-08-integration.md",
      "deps": ["kernel-optimize"],
      "requires_artifacts": [
        "problems/geak_results.json",
        "forks/manifest.json"
      ],
      "critical": true,
      "required_context": ["OUTPUT_DIR", "CONFIG_KEY", "FRAMEWORK", "SCRIPTS_DIR", "PROBLEMS_DIR", "OPTIMIZED_DIR", "REPO_DIR", "HF_CACHE", "RESULTS_DIR", "TEMPLATES_DIR", "GPUS", "SKIP_INTEGRATION"],
      "monitor_context_fields": {
        "source_artifacts": [
          "results/optimization_comparison.json",
          "results/integration_manifest.json",
          "results/dispatch_verification.json"
        ],
        "scalars": [
          "dispatch_verified",
          "expected_symbol_total_count",
          "vendor_symbol_leaked_count",
          "redirect_honored_count",
          "redirect_required_count",
          "libraries_rebuilt_ok_count",
          "libraries_rebuild_failed_count",
          "artifacts_valid",
          "performance_gate",
          "e2e_speedup",
          "ttft_regression_pct"
        ]
      },
      "quality": {
        "checks": [
          { "name": "comparison_exists", "type": "file_exists", "path": "results/optimization_comparison.json" },
          { "name": "integration_manifest_exists", "type": "file_exists", "path": "results/integration_manifest.json" },
          { "name": "dispatch_verification_exists", "type": "file_exists", "path": "results/dispatch_verification.json" }
        ],
        "detection_rules": "Fail integration when any of: results/dispatch_verification.json is missing; dispatch_verified == false (the patched kernel did not actually fire on the rebuilt env); vendor_symbol_leaked_count > 0 (vendor baseline symbol is still being dispatched, indicating a double-load or shadowing failure); redirect_honored_count < redirect_required_count (a planned dispatch redirect was not effective); libraries_rebuild_failed_count > 0; optimization_comparison.json is missing or artifacts_valid is false; performance_gate == fail; e2e_speedup < 1.0. A performance_gate == warn outcome with dispatch_verified == true is a usable measured result and should not be FAILed by itself, but a TTFT regression > 20% is still a FAIL.",
        "detection_rules_structured": [
          {"field": "dispatch_verified", "op": "eq", "value": false, "verdict": "FAIL"},
          {"field": "vendor_symbol_leaked_count", "op": "gt", "value": 0, "verdict": "FAIL"},
          {"field": "libraries_rebuild_failed_count", "op": "gt", "value": 0, "verdict": "FAIL"},
          {"field": "performance_gate", "op": "eq", "value": "fail", "verdict": "FAIL"},
          {"field": "e2e_speedup", "op": "lt", "value": 1.0, "verdict": "FAIL"},
          {"field": "ttft_regression_pct", "op": "gt", "value": 20.0, "verdict": "FAIL", "condition": "performance_gate == warn"}
        ],
        "detection_rules_structured_v2": [
          {"field": "baseline_integrity_match", "op": "eq", "value": false, "verdict": "FAIL", "category": "baseline_drift"},
          {"field": "cross_kernel_delta_pct", "op": "gt", "value": {"$ref": "$CROSS_KERNEL_THRESHOLD"}, "verdict": "FAIL", "category": "cross_kernel_interference"},
          {"field": "stale_artifacts_detected", "op": "eq", "value": true, "verdict": "FAIL", "category": "stale_artifact"}
        ]
      },
      "rca_artifact": {
        "output": "results/integration_rca.json",
        "analysis_context": [
          "agent-results/phase-08-result.md",
          "monitor/phase-08-review.md",
          "results/integration_manifest.json",
          "results/optimization_comparison.json",
          "results/dispatch_verification.json",
          "results/baseline_dispatch_trace.json",
          "forks/manifest.json"
        ]
      },
      "fallback_target": "kernel-optimize",
      "terminal_policy": "stop"
    },
    "report-generate": {
      "index": 9,
      "agent": "phase-09-report-generate.md",
      "deps": ["integration"],
      "conditional_deps": {
        "when_absent": "integration",
        "fallback_dep": "kernel-optimize"
      },
      "critical": false,
      "required_context": ["OUTPUT_DIR", "RESULTS_DIR", "SCRIPTS_DIR", "TEMPLATES_DIR", "REPORT_DIR", "CONFIG_KEY", "FRAMEWORK", "ENV_INFO_FILE", "PROBLEMS_DIR"],
      "sticky": ["final_speedup", "report_path"]
    }
  },
  "modes": {
    "benchmark": ["env", "config", "benchmark", "benchmark-analyze"],
    "profile": ["env", "config", "profile", "profile-analyze"],
    "full": ["env", "config", "benchmark", "benchmark-analyze", "profile", "profile-analyze"],
    "optimize": ["env", "config", "benchmark", "benchmark-analyze", "profile", "profile-analyze", "problem-generate", "kernel-optimize", "integration", "report-generate"],
    "optimize-only": ["env", "config", "problem-generate", "kernel-optimize", "integration", "report-generate"],
    "monitor": ["env", "config", "benchmark", "benchmark-analyze", "profile", "profile-analyze", "problem-generate", "kernel-optimize", "integration", "report-generate"]
  },
  "_mode_notes": {
    "optimize-only": "Requires prior profiling run — expects results/gap_analysis/gap_analysis.json and results/profile_analysis.json"
  },
  "parallel_groups": {
    "full": [["benchmark", "profile"], ["benchmark-analyze", "profile-analyze"]],
    "optimize": [["benchmark", "profile"], ["benchmark-analyze", "profile-analyze"]],
    "monitor": [["benchmark", "profile"], ["benchmark-analyze", "profile-analyze"]]
  },
  "rerun": { "max_per_phase": 1000, "max_total": 10000 },
  "systemic_rca": {
    "agent": "systemic-rca.md",
    "artifact": "results/systemic_rca.json",
    "rca_history_path": "results/rca_history.json",
    "trigger": "two consecutive per-phase RCAs share the same fingerprint",
    "analysis_context": [
      "results/rca_history.json",
      "results/*_rca.json",
      "agent-results/phase-*-result.md",
      "monitor/running-summary.md",
      "monitor/phase-*-review.md",
      "monitor/phase-*-predicate.json",
      "progress.json",
      "results/optimization_comparison.json",
      "results/integration_manifest.json",
      "results/dispatch_verification.json",
      "results/baseline_dispatch_trace.json",
      "results/preflight_dispatch_trace.json",
      "results/rebuild_*.log",
      "forks/manifest.json",
      "problems/geak_results.json",
      "problems/optimization_manifest.json",
      "problems/redirect_plan.json",
      "results/profile_analysis.json"
    ]
  },
  "timeouts": {
    "default_minutes": 30,
    "overrides": {
      "benchmark": 60,
      "profile": 60,
      "kernel-optimize": 90,
      "integration": 60
    }
  },
  "_schema_notes": {
    "monitor_context_fields": "Active — compact context extraction for monitor reviews on critical phases",
    "detection_rules_structured": "Active — used by monitor/orchestrator guidance; deterministic runner evaluation is enabled when V2_MONITOR=true",
    "parallel_groups": "Planning metadata for orchestrator-level concurrency; deterministic runner currently executes resolved phase lists sequentially",
    "human_loop": "Registry default is false; runtime escalation behavior reads HUMAN_LOOP from config and requires V2_MONITOR",
    "rerun": "Default budget is intentionally large (max_per_phase=1000, max_total=10000) so RCA-driven retry can keep working automatically. Repeated identical RCA fingerprints still trigger systemic-rca before another retry. Custom registries may set smaller positive caps for fast tests.",
    "terminal_policy_allow_partial_report": "Removed from kernel-optimize and integration. The runner never auto-skips to report-generate after a critical FAIL; instead it pauses with status=awaiting_user_instruction and writes monitor/user_decision_request.json so the user (or dispatcher) chooses retry / fallback / stop / generate-report."
  },
  "context_sources": {
    "CONFIG_KEY":                { "source": "config" },
    "OUTPUT_DIR":                { "source": "config" },
    "MODE":                      { "source": "config" },
    "REPO_DIR":                  { "source": "config" },
    "REPO_URL":                  { "source": "config" },
    "HF_CACHE":                  { "source": "config" },
    "SCRIPTS_DIR":               { "source": "config" },
    "PROFILE_DIR":               { "source": "config" },
    "RESULTS_DIR":               { "source": "config" },
    "PROBLEMS_DIR":              { "source": "config" },
    "OPTIMIZED_DIR":             { "source": "config" },
    "GEAK_DIR":                  { "source": "config" },
    "GEAK_OE_DIR":               { "source": "config" },
    "OPTIMIZE_SCOPE":            { "source": "config" },
    "VLLM_VERSION":              { "source": ["config", "artifact"], "config_key": "VLLM_VERSION", "artifact_fallback": {"path": "env_info.json", "field": "vllm_version"} },
    "KERNEL_SOURCE_MAP_PATH":    { "source": "config", "default": "{RESOURCES_DIR}/kernel_source_map.yaml" },
    "LIBRARY_PINS_PATH":         { "source": "config", "default": "{RESOURCES_DIR}/library_pins.yaml" },
    "SKIP_INTEGRATION":          { "source": "config", "default": "false" },
    "OPTIMIZE_PRIORITY_THRESHOLD": { "source": "config" },
    "ENV_INFO_FILE":             { "source": "config" },
    "RESOURCES_DIR":             { "source": "config" },
    "TEMPLATES_DIR":             { "source": "config" },
    "REPORT_DIR":                { "source": "config" },
    "FRAMEWORK":                 { "source": ["config", "artifact"], "config_key": "FRAMEWORK", "artifact_fallback": {"path": "results/sweep_configs.json", "field": "framework"} },
    "PRECISION":                 { "source": "artifact", "path": "results/sweep_configs.json", "field": "precision" },
    "GPUS":                      { "source": "config" },
    "DRY_RUN_NOTE":              { "source": "config" },
    "ENFORCE_EAGER_FLAG":        { "source": "config" },
    "FILTER_EP":                 { "source": "config" },
