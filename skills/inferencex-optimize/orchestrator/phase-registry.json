{
  "schema_version": "1.0",
  "max_context_lines": 500,
  "phases": {
    "env": {
      "index": 0,
      "agent": "phase-00-env-setup.md",
      "deps": [],
      "critical": false,
      "required_context": ["CONFIG_KEY", "OUTPUT_DIR", "MODE", "REPO_DIR", "REPO_URL", "HF_CACHE", "SCRIPTS_DIR", "GEAK_DIR", "GEAK_OE_DIR", "ENV_INFO_FILE"],
      "sticky": ["gpu_arch", "gpu_count", "container_image"]
    },
    "config": {
      "index": 1,
      "agent": "phase-01-config-parse.md",
      "deps": ["env"],
      "critical": false,
      "required_context": ["CONFIG_KEY", "OUTPUT_DIR", "REPO_DIR", "SCRIPTS_DIR", "FILTER_EP", "FILTER_TP", "FILTER_CONC_START", "FILTER_CONC_END", "FILTER_SEQ"],
      "sticky": ["tp_size", "ep_size", "seq_lengths", "concurrency_levels"]
    },
    "benchmark": {
      "index": 2,
      "agent": "phase-02-benchmark.md",
      "deps": ["config"],
      "critical": true,
      "required_context": ["CONFIG_KEY", "OUTPUT_DIR", "SCRIPTS_DIR", "REPO_DIR", "HF_CACHE", "PROFILE_DIR", "GPUS", "DRY_RUN_NOTE"],
      "sticky": ["baseline_tpot", "baseline_throughput"],
      "monitor_context_fields": {
        "source_artifacts": [],
        "scalars": ["benchmark_result_status", "benchmarks_succeeded", "baseline_artifacts_ready"]
      },
      "quality": {
        "checks": [
          { "name": "results_exist", "type": "file_exists", "path": "results/" },
          { "name": "runs_completed", "type": "metric_threshold", "field": "benchmarks_succeeded", "min": 1 }
        ],
        "detection_rules": "Fail benchmark when any of: expected result JSONs are missing; benchmarks_succeeded < 1; throughput artifacts are present but invalid or clearly incomplete; the benchmark phase reports an environment or harness issue that makes downstream comparison unsafe.",
        "detection_rules_structured": [
          {"field": "benchmarks_succeeded", "op": "lt", "value": 1, "verdict": "FAIL"},
          {"field": "benchmark_result_status", "op": "eq", "value": "failed", "verdict": "FAIL"},
          {"field": "baseline_artifacts_ready", "op": "eq", "value": false, "verdict": "FAIL"}
        ]
      },
      "rca_artifact": {
        "output": "results/benchmark_root_cause.json",
        "analysis_context": ["results/", "agent-results/phase-02-result.md"]
      },
      "terminal_policy": "stop"
    },
    "benchmark-analyze": {
      "index": 3,
      "agent": "phase-03-benchmark-analyze.md",
      "deps": ["benchmark"],
      "critical": false,
      "required_context": ["OUTPUT_DIR", "SCRIPTS_DIR", "REPORT_DIR", "TEMPLATES_DIR"],
      "sticky": ["gap_analysis_summary", "best_concurrency"],
      "monitor_context_fields": {
        "source_artifacts": ["results/benchmark_summary.json"],
        "scalars": ["results_analyzed", "bottlenecks_found"]
      },
      "quality": {
        "checks": [
          { "name": "summary_exists", "type": "file_exists", "path": "results/benchmark_summary.json" },
          { "name": "results_analyzed", "type": "metric_threshold", "field": "results_analyzed", "min": 1 }
        ],
        "detection_rules": "Fail when benchmark_summary.json is missing or results_analyzed < 1.",
        "detection_rules_structured": [
          {"field": "results_analyzed", "op": "lt", "value": 1, "verdict": "FAIL"}
        ]
      }
    },
    "profile": {
      "index": 4,
      "agent": "phase-04-profile.md",
      "deps": ["config"],
      "critical": false,
      "required_context": ["CONFIG_KEY", "OUTPUT_DIR", "SCRIPTS_DIR", "REPO_DIR", "HF_CACHE", "PROFILE_DIR", "GPUS", "DRY_RUN_NOTE", "ENFORCE_EAGER_FLAG", "FILTER_EP", "FILTER_TP", "FILTER_CONC_START", "FILTER_CONC_END", "FILTER_SEQ"]
    },
    "profile-analyze": {
      "index": 5,
      "agent": "phase-05-profile-analyze.md",
      "deps": ["profile"],
      "critical": true,
      "required_context": ["OUTPUT_DIR", "GPU_ARCH", "SCRIPTS_DIR", "RESOURCES_DIR", "REPORT_DIR", "TEMPLATES_DIR", "PROFILE_DIR"],
      "sticky": ["top_kernels", "kernel_time_pct"],
      "monitor_context_fields": {
        "source_artifacts": ["results/trace_manifest.json"],
        "scalars": ["trace_integrity_status", "tracelens_status", "phase_split_status", "trace_count", "world_size", "phase_split_inputs_ready", "roofline_coverage_pct"]
      },
      "quality": {
        "checks": [
          { "name": "traces_valid", "type": "file_exists", "path": "profiles/" },
          { "name": "analysis_produced", "type": "file_exists", "path": "results/profile_analysis.json" },
          { "name": "trace_manifest_exists", "type": "file_exists", "path": "results/trace_manifest.json" }
        ],
        "detection_rules": "Fail profile analysis when any of: gzip decompression fails end-to-end; traceEvents are missing; trace files are trivially small or obviously incomplete; required primary trace or phase-split inputs are missing for optimize mode; TraceLens or phase-split roofline is required but not actually usable. Check trace_manifest.json for per-trace integrity status and phase_split_inputs_ready flag. Warn when roofline_coverage_pct < 50 (majority of top kernel time lacks roofline data, typically due to CUDA graph wrapping).",
        "detection_rules_structured": [
          {"field": "trace_integrity_status", "op": "eq", "value": "corrupt", "verdict": "FAIL"},
          {"field": "trace_integrity_status", "op": "eq", "value": "missing", "verdict": "FAIL"},
          {"field": "trace_count", "op": "lt", "value": 1, "verdict": "FAIL"},
          {"field": "phase_split_inputs_ready", "op": "eq", "value": false, "verdict": "WARN"},
          {"field": "roofline_coverage_pct", "op": "lt", "value": 50, "verdict": "WARN"}
        ]
      },
      "rca_artifact": {
        "output": "results/profile_root_cause.json",
        "analysis_context": ["profiles/", "results/trace_manifest.json", "agent-results/phase-05-result.md"]
      },
      "fallback_target": "profile",
      "terminal_policy": "stop"
    },
    "problem-generate": {
      "index": 6,
      "agent": "phase-06-problem-generate.md",
      "deps": ["profile-analyze"],
      "requires_artifacts": [
        "results/gap_analysis/gap_analysis.json",
        "results/profile_analysis.json"
      ],
      "critical": true,
      "required_context": ["OUTPUT_DIR", "GPU_ARCH", "TOP_KERNELS", "SCRIPTS_DIR", "PROBLEMS_DIR", "OPTIMIZED_DIR", "FRAMEWORK", "PRECISION", "OPTIMIZE_PRIORITY_THRESHOLD"],
      "sticky": ["optimization_targets", "problem_count"],
      "monitor_context_fields": {
        "source_artifacts": ["problems/optimization_manifest.json"],
        "scalars": ["problems_generated", "max_kernel_types_per_problem"]
      },
      "quality": {
        "checks": [
          { "name": "manifest_exists", "type": "file_exists", "path": "problems/optimization_manifest.json" },
          { "name": "problems_generated", "type": "metric_threshold", "field": "problems_generated", "min": 1 }
        ],
        "detection_rules": "Fail when optimization_manifest.json is missing or problems_generated < 1. Warn when max_kernel_types_per_problem > 2 (a single problem file mixes unrelated kernel types, indicating bad grouping — e.g. MoE GEMM + RMSNorm + attention in one file).",
        "detection_rules_structured": [
          {"field": "problems_generated", "op": "lt", "value": 1, "verdict": "FAIL"},
          {"field": "max_kernel_types_per_problem", "op": "gt", "value": 2, "verdict": "WARN"}
        ]
      },
      "rca_artifact": {
        "output": "results/problem_gen_root_cause.json",
        "analysis_context": ["problems/optimization_manifest.json", "results/profile_analysis.json", "agent-results/phase-06-result.md"]
      },
      "terminal_policy": "stop"
    },
    "kernel-optimize": {
      "index": 7,
      "agent": "phase-07-kernel-optimize.md",
      "deps": ["problem-generate"],
      "critical": true,
      "required_context": ["OUTPUT_DIR", "GPU_ARCH", "GEAK_MODE", "SCRIPTS_DIR", "PROBLEMS_DIR", "OPTIMIZED_DIR", "REPO_DIR", "HF_CACHE", "ENV_INFO_FILE", "OPTIMIZE_SCOPE", "GEAK_DIR", "GEAK_OE_DIR", "GPUS", "CONFIG_KEY"],
      "monitor_context_fields": {
        "source_artifacts": [],
        "scalars": ["compiled_count", "best_speedup", "winning_kernel_count", "optimization_coverage_status", "expected_improvement_status"]
      },
      "quality": {
        "checks": [
          { "name": "kernels_compiled", "type": "metric_threshold", "field": "compiled_count", "min": 1 }
        ],
        "detection_rules": "Fail kernel-optimize when any of: compiled_count < 1; best_speedup <= 1.0 and expected_improvement_status != parity_or_blocked; expected_improvement_status = not_attempted (high-value targets were skipped without any optimization attempt); winning kernels are missing from optimized/; optimization logs show the phase stalled without producing a usable winner or blocker explanation. Warn instead of FAIL when expected_improvement_status = parity_or_blocked and the blockers are structured (for example true_kernel_parity or framework_limit), so inherently unimprovable targets are captured instead of retried blindly.",
        "detection_rules_structured": [
          {"field": "compiled_count", "op": "lt", "value": 1, "verdict": "FAIL"},
          {"field": "best_speedup", "op": "le", "value": 1.0, "verdict": "FAIL", "condition": "expected_improvement_status != parity_or_blocked"},
          {"field": "expected_improvement_status", "op": "eq", "value": "not_attempted", "verdict": "FAIL"},
          {"field": "expected_improvement_status", "op": "eq", "value": "parity_or_blocked", "verdict": "WARN"}
        ]
      },
      "rca_artifact": {
        "output": "results/kernel_opt_root_cause.json",
        "analysis_context": ["problems/geak_results.json", "optimized/", "agent-results/phase-07-result.md"]
      },
      "fallback_target": "problem-generate",
      "terminal_policy": "allow_partial_report"
    },
    "integration": {
      "index": 8,
      "agent": "phase-08-integration.md",
      "deps": ["kernel-optimize"],
      "critical": true,
      "required_context": ["OUTPUT_DIR", "CONFIG_KEY", "FRAMEWORK", "SCRIPTS_DIR", "PROBLEMS_DIR", "OPTIMIZED_DIR", "REPO_DIR", "HF_CACHE", "RESULTS_DIR", "TEMPLATES_DIR", "GPUS"],
      "monitor_context_fields": {
        "source_artifacts": ["results/optimization_comparison.json"],
        "scalars": ["artifacts_valid", "performance_gate", "e2e_speedup", "ttft_regression_pct", "ttft_upgraded"]
      },
      "quality": {
        "checks": [
          { "name": "plugin_generated", "type": "file_exists", "path": "optimized/" },
          { "name": "comparison_exists", "type": "file_exists", "path": "results/optimization_comparison.json" },
          { "name": "integration_manifest_exists", "type": "file_exists", "path": "results/integration_manifest.json" }
        ],
        "detection_rules": "Fail integration when any of: optimization_comparison.json is missing; artifacts_valid is false; validation_status = fail; performance_gate = fail; a top-priority winner is still unintegrated without a structured blocker. Warn when validation_status = warn and the only performance issue is the accepted 0.97 <= speedup < 1.0 band. Performance policy: pass when speedup >= 1.0; warn when 0.97 <= speedup < 1.0; fail when speedup < 0.97. Severe TTFT regression should upgrade a weak result from warn to fail. Read artifacts_valid, performance_gate, e2e_speedup, and ttft_regression_pct from results/optimization_comparison.json.",
        "detection_rules_structured": [
          {"field": "performance_gate", "op": "eq", "value": "fail", "verdict": "FAIL"},
          {"field": "e2e_speedup", "op": "lt", "value": 0.97, "verdict": "FAIL"},
          {"field": "e2e_speedup", "op": "lt", "value": 1.0, "verdict": "WARN"},
          {"field": "ttft_regression_pct", "op": "gt", "value": 20.0, "verdict": "FAIL", "condition": "performance_gate == warn"}
        ]
      },
      "rca_artifact": {
        "output": "results/integration_root_cause.json",
        "analysis_context": ["problems/geak_results.json", "results/optimization_comparison.json", "optimized/", "agent-results/phase-08-result.md"]
      },
      "fallback_target": "kernel-optimize",
      "terminal_policy": "allow_partial_report"
    },
    "report-generate": {
      "index": 9,
      "agent": "phase-09-report-generate.md",
      "deps": ["integration"],
      "conditional_deps": {
        "when_absent": "integration",
        "fallback_dep": "kernel-optimize"
      },
      "critical": false,
      "required_context": ["OUTPUT_DIR", "RESULTS_DIR", "SCRIPTS_DIR", "TEMPLATES_DIR", "REPORT_DIR", "CONFIG_KEY", "FRAMEWORK", "ENV_INFO_FILE", "PROBLEMS_DIR"],
      "sticky": ["final_speedup", "report_path"]
    }
  },
  "modes": {
    "benchmark": ["env", "config", "benchmark", "benchmark-analyze"],
    "profile": ["env", "config", "profile", "profile-analyze"],
    "full": ["env", "config", "benchmark", "benchmark-analyze", "profile", "profile-analyze"],
    "optimize": ["env", "config", "benchmark", "benchmark-analyze", "profile", "profile-analyze", "problem-generate", "kernel-optimize", "integration", "report-generate"],
    "optimize-only": ["env", "config", "problem-generate", "kernel-optimize", "integration", "report-generate"]
  },
  "_mode_notes": {
    "optimize-only": "Requires prior profiling run — expects results/gap_analysis/gap_analysis.json and results/profile_analysis.json"
  },
  "parallel_groups": {
    "full": [["benchmark", "profile"], ["benchmark-analyze", "profile-analyze"]],
    "optimize": [["benchmark", "profile"], ["benchmark-analyze", "profile-analyze"]]
  },
  "rerun": { "max_per_phase": 2, "max_total": 5 },
  "timeouts": {
    "default_minutes": 30,
    "overrides": {
      "benchmark": 60,
      "profile": 60,
      "kernel-optimize": 90,
      "integration": 60
    }
  },
  "_schema_notes": {
    "monitor_context_fields": "Active — structured context extraction for monitor, used by critical phases",
    "detection_rules_structured": "Active — typed predicates for verdict automation on critical phases",
    "parallel_groups": "Active — concurrent phase execution groups for full and optimize modes"
  },
  "context_sources": {
    "CONFIG_KEY":                { "source": "config" },
    "OUTPUT_DIR":                { "source": "config" },
    "MODE":                      { "source": "config" },
    "REPO_DIR":                  { "source": "config" },
    "REPO_URL":                  { "source": "config" },
    "HF_CACHE":                  { "source": "config" },
    "SCRIPTS_DIR":               { "source": "config" },
    "PROFILE_DIR":               { "source": "config" },
    "RESULTS_DIR":               { "source": "config" },
    "PROBLEMS_DIR":              { "source": "config" },
    "OPTIMIZED_DIR":             { "source": "config" },
    "GEAK_DIR":                  { "source": "config" },
    "GEAK_OE_DIR":               { "source": "config" },
    "GEAK_MODE":                 { "source": "config" },
    "OPTIMIZE_SCOPE":            { "source": "config" },
    "OPTIMIZE_PRIORITY_THRESHOLD": { "source": "config" },
    "ENV_INFO_FILE":             { "source": "config" },
    "RESOURCES_DIR":             { "source": "config" },
    "TEMPLATES_DIR":             { "source": "config" },
    "REPORT_DIR":                { "source": "config" },
    "FRAMEWORK":                 { "source": "artifact", "path": "results/sweep_configs.json", "field": "framework" },
    "PRECISION":                 { "source": "artifact", "path": "results/sweep_configs.json", "field": "precision" },
    "GPUS":                      { "source": "config" },
    "DRY_RUN_NOTE":              { "source": "config" },
    "ENFORCE_EAGER_FLAG":        { "source": "config" },
    "FILTER_EP":                 { "source": "config" },
    "FILTER_TP":                 { "source": "config" },
    "FILTER_CONC_START":         { "source": "config" },
    "FILTER_CONC_END":           { "source": "config" },
    "FILTER_SEQ":                { "source": "config" },
    "GPU_ARCH":                  { "source": "artifact", "path": "env_info.json", "field": "gpu_arch" },
    "TOP_KERNELS":               { "source": "artifact", "path": "results/gap_analysis/gap_analysis.json", "field": "top_kernels" }
  }
}
