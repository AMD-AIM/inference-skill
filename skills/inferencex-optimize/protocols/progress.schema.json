{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "progress.json",
  "description": "Run state tracking. Single writer: the orchestrator (legacy) or the runner (runner path).",
  "type": "object",
  "required": ["schema_version", "phases_completed", "current_phase", "status", "retry_counts", "total_reruns", "fallbacks_used"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "phases_completed": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Ordered list of completed phase keys"
    },
    "current_phase": {
      "type": ["string", "null"],
      "description": "Phase key currently executing, or null when idle/complete"
    },
    "status": {
      "type": "string",
      "enum": ["running", "completed", "failed"]
    },
    "retry_counts": {
      "type": "object",
      "additionalProperties": { "type": "integer", "minimum": 0 },
      "description": "Map of phase key to retry count"
    },
    "total_reruns": {
      "type": "integer",
      "minimum": 0
    },
    "fallbacks_used": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["phase_key", "fallback_target"],
        "properties": {
          "phase_key": { "type": "string" },
          "fallback_target": { "type": "string" }
        }
      }
    },
    "mode": {
      "type": "string",
      "description": "Selected run mode"
    },
    "resolved_phases": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Resolved phase list after applying SKIP_INTEGRATION and conditional_deps"
    }
  },
  "additionalProperties": false
}
